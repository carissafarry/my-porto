{
  "name": "nextarter-chakra",
  "version": "0.1.0",
  "private": true,
  "author": "sozonome",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:turbo": "turbo run build",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:turbo": "turbo run lint",
    "type-check": "tsc --noEmit",
    "type-check:turbo": "turbo run type-check",
    "test:e2e": "playwright test",
    "format": "prettier --write --ignore-path .gitignore src",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 standard-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "husky install"
  },
  "dependencies": {
    "@chakra-ui/next-js": "^2.4.2",
    "@chakra-ui/react": "^2.10.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^14.2.35",
    "@types/react-dom": "^18.3.7",
    "@types/slug": "^5.0.9",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "framer-motion": "^10.18.0",
    "next": "^14.2.35",
    "next-pwa": "^5.6.0",
    "querystring": "^0.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^4.12.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^3.0.1",
    "remark-toc": "^9.0.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^17.8.1",
    "@commitlint/cz-commitlint": "^17.8.1",
    "@playwright/test": "^1.60.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "axios": "^1.16.0",
    "commitizen": "^4.3.1",
    "commitlint": "^17.8.1",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "front-matter": "^4.0.2",
    "gray-matter": "^4.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^13.3.0",
    "next-mdx-remote": "^4.4.1",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.8.3",
    "rehype-highlight": "^7.0.2",
    "standard-version": "^9.5.0",
    "swr": "^2.4.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": "20.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.33.0"
}
